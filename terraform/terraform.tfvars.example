name         = "openbase-api-core"
environment  = "dev"
aws_region   = "us-east-1"
web_hostname = "api.example.com"
cdn_hostname = "cdn.example.com"
cloudflare_zone_name = "example.com"
frontend_cors_allowed_origins = ["https://api.example.com"]

app_image = "123456789012.dkr.ecr.us-east-1.amazonaws.com/openbase-api-core-dev-app:bootstrap"

db_password = "replace-me"

cloudflare_origin_cert_parameter_name = "/openbase-api-core/dev/cloudflare-origin-cert"
cloudflare_origin_key_parameter_name  = "/openbase-api-core/dev/cloudflare-origin-key"

common_environment = {
  DJANGO_DEBUG = "0"
}

common_secrets = {
  DJANGO_SECRET_KEY = "arn:aws:ssm:us-east-1:123456789012:parameter/openbase/dev/django-secret-key"
}
