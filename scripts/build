#!/usr/bin/env bash

set -euo pipefail

APP_NAME="$1"
GH_PAT="$2"
APP_REQUIREMENTS="$3"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd -- "${SCRIPT_DIR}/.." && pwd)"

# shellcheck disable=SC2016
WEB_CMD='gunicorn config.asgi:application --log-file - -k uvicorn.workers.UvicornWorker --bind 0.0.0.0:$PORT'
WORKER_CMD="taskiq worker --log-level=INFO --max-threadpool-threads=2 config.taskiq_config:broker config.taskiq_tasks"
BEAT_CMD="taskiq scheduler --log-level=INFO config.taskiq_config:scheduler config.taskiq_tasks"
RELEASE_CMD='python3 manage.py migrate'

APP_REQUIREMENTS_TMP="./.app_requirements_docker.build.$$"
NOCACHE_TMP="./.nocache.build.$$"

cleanup() {
    "${SCRIPT_DIR}/cleanup_build_artifacts"
}

trap cleanup EXIT

cd "${REPO_DIR}"

"${SCRIPT_DIR}/cleanup_build_artifacts"

# Write app requirements to file - ensure git+ prefix for GitHub URLs
if [[ "${APP_REQUIREMENTS}" == https://github.com/* ]]; then
    printf 'git+%s\n' "${APP_REQUIREMENTS}" > "${APP_REQUIREMENTS_TMP}"
else
    printf '%s\n' "${APP_REQUIREMENTS}" > "${APP_REQUIREMENTS_TMP}"
fi

date > "${NOCACHE_TMP}"

# Build each configuration
for type in web worker beat release; do
    case "$type" in
        web)     CMD="${WEB_CMD}" ;;
        worker)  CMD="${WORKER_CMD}" ;;
        beat)    CMD="${BEAT_CMD}" ;;
        release) CMD="${RELEASE_CMD}" ;;
    esac

    DOCKERFILE_TMP="./.dockerfile.build.${type}.$$"
    sed \
        -e "s|COPY nocache.txt /tmp/nocache.txt|COPY ${NOCACHE_TMP#./} /tmp/nocache.txt|" \
        -e "s|COPY app_requirements_docker.txt \\.|COPY ${APP_REQUIREMENTS_TMP#./} app_requirements_docker.txt|" \
        ./Dockerfile > "${DOCKERFILE_TMP}"
    printf 'CMD %s\n' "${CMD}" >> "${DOCKERFILE_TMP}"
    docker buildx build --platform linux/amd64 --push -t "registry.heroku.com/${APP_NAME}/${type}:latest" \
        -f "${DOCKERFILE_TMP}" \
        --build-arg GH_PAT="${GH_PAT}" \
        --provenance false .
    rm -f "${DOCKERFILE_TMP}"
done
