#!/usr/bin/env bash

set -euo pipefail

if [[ $# -lt 1 || $# -gt 4 ]]; then
    echo "Usage: $(basename "$0") <stack-name> [app-requirements] [environment] [image-tag]" >&2
    exit 2
fi

STACK_NAME="$1"
APP_REQUIREMENTS="${2:-${APP_REQUIREMENTS:-}}"
ENVIRONMENT="${3:-dev}"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/_aws_common.sh
source "${SCRIPT_DIR}/_aws_common.sh"

IMAGE_TAG="${4:-${IMAGE_TAG:-$(default_image_tag)}}"
WEB_IMAGE_REPOSITORY="$(ecr_repository_uri "${STACK_NAME}" "${ENVIRONMENT}" "web")"
WORKER_IMAGE_REPOSITORY="$(ecr_repository_uri "${STACK_NAME}" "${ENVIRONMENT}" "worker")"

require_commands aws docker git sed uv
ensure_ecr_repository "${STACK_NAME}" "${ENVIRONMENT}" "web"
ensure_ecr_repository "${STACK_NAME}" "${ENVIRONMENT}" "worker"
ecr_login

# shellcheck disable=SC2016
WEB_CMD='/app/.venv/bin/gunicorn config.asgi:application --log-file - -k uvicorn.workers.UvicornWorker --bind 0.0.0.0:$PORT'
WORKER_CMD="/app/.venv/bin/taskiq worker --log-level=INFO --max-threadpool-threads=2 config.taskiq_config:broker config.taskiq_tasks"

PRIVATE_GITHUB_REPOS_TMP="./.private_github_repos.build.$$"
NOCACHE_TMP="./.nocache.build.$$"

cleanup() {
    "${SCRIPT_DIR}/cleanup_build_artifacts"
}

trap cleanup EXIT

cd "${REPO_DIR}"

"${SCRIPT_DIR}/cleanup_build_artifacts"

if [[ -z "${APP_REQUIREMENTS}" ]]; then
    printf '%s\n' "git+https://github.com/openbase-community/openbase-cloud-api" > "${PRIVATE_GITHUB_REPOS_TMP}"
else
    printf '%s' "${APP_REQUIREMENTS}" | tr ',' '\n' | while IFS= read -r requirement; do
        requirement="${requirement#"${requirement%%[![:space:]]*}"}"
        requirement="${requirement%"${requirement##*[![:space:]]}"}"
        if [[ -z "${requirement}" ]]; then
            continue
        fi
        if [[ "${requirement}" == https://github.com/* ]]; then
            printf 'git+%s\n' "${requirement}"
        else
            printf '%s\n' "${requirement}"
        fi
    done > "${PRIVATE_GITHUB_REPOS_TMP}"
fi

date > "${NOCACHE_TMP}"

build_image() {
    local type="$1"
    local cmd="$2"
    local repository="$3"
    local dockerfile_tmp
    dockerfile_tmp="./.dockerfile.build.${type}.$$"
    sed \
        -e "s|COPY nocache.txt /tmp/nocache.txt|COPY ${NOCACHE_TMP#./} /tmp/nocache.txt|" \
        -e "s|COPY private_github_repos.txt /tmp/private_github_repos.txt|COPY ${PRIVATE_GITHUB_REPOS_TMP#./} /tmp/private_github_repos.txt|" \
        ./Dockerfile > "${dockerfile_tmp}"
    printf 'CMD %s\n' "${cmd}" >> "${dockerfile_tmp}"
    docker buildx build \
        --platform linux/amd64 \
        --push \
        -t "${repository}:${IMAGE_TAG}" \
        -t "${repository}:latest" \
        -f "${dockerfile_tmp}" \
        --secret id=gh_pat,env=GH_PAT \
        --provenance false \
        .
    rm -f "${dockerfile_tmp}"
}

build_image web "${WEB_CMD}" "${WEB_IMAGE_REPOSITORY}"
build_image worker "${WORKER_CMD}" "${WORKER_IMAGE_REPOSITORY}"

echo "Built and pushed:"
echo "  ${WEB_IMAGE_REPOSITORY}:${IMAGE_TAG}"
echo "  ${WORKER_IMAGE_REPOSITORY}:${IMAGE_TAG}"
