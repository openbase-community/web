#!/usr/bin/env bash

set -euo pipefail

usage() {
    cat <<'EOF' >&2
Usage: build <stack-name> [app-requirements] [environment] [image-tag]

Examples:
  ./scripts/build openbase-api-core "https://github.com/openbase-community/openbase-cloud-api" prod
  ./scripts/build openbase-api-core prod

If app-requirements is omitted, the command reads APP_REQUIREMENTS from deploy/<environment>.env.
EOF
    exit 2
}

looks_like_app_requirements() {
    local value="$1"
    [[ "${value}" == *"://"* || "${value}" == git+* || "${value}" == *","* || "${value}" == */* ]]
}

if [[ $# -lt 1 || $# -gt 4 ]]; then
    usage
fi

STACK_NAME="$1"
shift
ENVIRONMENT="dev"
APP_REQUIREMENTS_INPUT="${APP_REQUIREMENTS:-}"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/internal/aws-common.sh
source "${SCRIPT_DIR}/internal/aws-common.sh"

if [[ $# -gt 0 ]]; then
    if looks_like_app_requirements "$1"; then
        APP_REQUIREMENTS_INPUT="$1"
        shift
    elif [[ -f "$(deploy_config_file_for_environment "$1")" ]]; then
        ENVIRONMENT="$1"
        shift
    elif [[ -z "${APP_REQUIREMENTS_INPUT}" ]]; then
        APP_REQUIREMENTS_INPUT="$1"
        shift
    fi
fi

if [[ $# -gt 0 ]]; then
    ENVIRONMENT="$1"
    shift
fi

IMAGE_TAG="${1:-${IMAGE_TAG:-$(generated_image_tag)}}"
if [[ $# -gt 1 ]]; then
    exit 2
fi
APP_IMAGE_REPOSITORY="$(ecr_repository_uri "${STACK_NAME}" "${ENVIRONMENT}" "app")"

if [[ -z "${APP_REQUIREMENTS_INPUT}" ]]; then
    APP_REQUIREMENTS_INPUT="$(require_deploy_config_value "${ENVIRONMENT}" "APP_REQUIREMENTS")"
fi

require_commands aws docker git sed uv
ensure_ecr_repository "${STACK_NAME}" "${ENVIRONMENT}" "app"
ecr_login

PRIVATE_GITHUB_REPOS_TMP="./.private_github_repos.build.$$"
NOCACHE_TMP="./.nocache.build.$$"

cleanup() {
    rm -f \
        ./Dockerfile.tmp \
        ./.dockerfile.build.* \
        ./.private_github_repos.build.* \
        ./.nocache.build.*
}

trap cleanup EXIT

cd "${REPO_DIR}"

cleanup

CANONICAL_APP_REQUIREMENTS=()

while IFS= read -r requirement; do
    requirement="${requirement#"${requirement%%[![:space:]]*}"}"
    requirement="${requirement%"${requirement##*[![:space:]]}"}"
    if [[ -z "${requirement}" ]]; then
        continue
    fi
    if [[ "${requirement}" == https://github.com/* ]]; then
        requirement="git+${requirement}"
    fi
    CANONICAL_APP_REQUIREMENTS+=("${requirement}")
done < <(printf '%s' "${APP_REQUIREMENTS_INPUT}" | tr ',' '\n')

[[ ${#CANONICAL_APP_REQUIREMENTS[@]} -gt 0 ]] || fail "No app requirements provided. Pass them explicitly or set APP_REQUIREMENTS in $(deploy_config_file_for_environment "${ENVIRONMENT}")"

printf '%s\n' "${CANONICAL_APP_REQUIREMENTS[@]}" > "${PRIVATE_GITHUB_REPOS_TMP}"

date > "${NOCACHE_TMP}"

DOCKERFILE_TMP="./.dockerfile.build.app.$$"

sed \
    -e "s|COPY nocache.txt /tmp/nocache.txt|COPY ${NOCACHE_TMP#./} /tmp/nocache.txt|" \
    -e "s|COPY private_github_repos.txt /tmp/private_github_repos.txt|COPY ${PRIVATE_GITHUB_REPOS_TMP#./} /tmp/private_github_repos.txt|" \
    ./Dockerfile > "${DOCKERFILE_TMP}"

docker buildx build \
    --platform linux/amd64 \
    --push \
    -t "${APP_IMAGE_REPOSITORY}:${IMAGE_TAG}" \
    -t "${APP_IMAGE_REPOSITORY}:latest" \
    -f "${DOCKERFILE_TMP}" \
    --secret id=gh_pat,env=GH_PAT \
    --provenance false \
    .

rm -f "${DOCKERFILE_TMP}"

set_deploy_config_value "${ENVIRONMENT}" "APP_REQUIREMENTS" "$(IFS=,; printf '%s' "${CANONICAL_APP_REQUIREMENTS[*]}")"
set_deploy_config_value "${ENVIRONMENT}" "IMAGE_TAG" "${IMAGE_TAG}"

echo "Built and pushed:"
echo "  ${APP_IMAGE_REPOSITORY}:${IMAGE_TAG}"
echo "Updated deploy config:"
echo "  $(deploy_config_file_for_environment "${ENVIRONMENT}")"
