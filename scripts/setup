#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd -- "${SCRIPT_DIR}/.." && pwd)"
WORKSPACE_DIR="$(cd -- "${REPO_DIR}/.." && pwd)"
ENV_FILE="${WORKSPACE_DIR}/.env"
INTERACTIVE=1

usage() {
    cat <<EOF
Usage: $(basename "$0") [options]

Options:
  --env-file PATH         Use a specific .env file. Default: ${ENV_FILE}
  -y, --yes               Run non-interactively.
  --non-interactive       Run non-interactively.
  -h, --help              Show this help text.
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --env-file)
            shift
            if [[ $# -eq 0 ]]; then
                echo "Missing path for --env-file" >&2
                exit 2
            fi
            ENV_FILE="$1"
            ;;
        -y|--yes|--non-interactive)
            INTERACTIVE=0
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "Unknown option: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
    shift
done

py() {
    uv run python "$@"
}

pushd "${REPO_DIR}" >/dev/null

# Check for .env file and prompt user if it doesn't exist
if [ ! -e "${ENV_FILE}" ]; then
    if [ "${INTERACTIVE}" -eq 0 ]; then
        echo "Missing .env file: ${ENV_FILE}" >&2
        exit 1
    fi

    echo "Please add an .env file: ${ENV_FILE}"
    echo "Press Enter once you have created ${ENV_FILE} to continue..."
    read -r
fi

# Run docker compose build
docker compose --env-file "${ENV_FILE}" build

# Spin up the database
docker compose --env-file "${ENV_FILE}" up -d db

# Wait for the database to be ready
echo "Waiting for the database to be ready..."
sleep 5

# Run database migrations
echo "Running database migrations..."
py manage.py migrate

# Check for existing superuser and ensure its development defaults
echo "Ensuring development superuser..."
DEV_SUPERUSER_ARGS=()
if [ "${INTERACTIVE}" -eq 0 ]; then
    DEV_SUPERUSER_ARGS+=(--non-interactive)
fi
py manage.py ensure_dev_superuser "${DEV_SUPERUSER_ARGS[@]}"

# Create default sites and site attributes
echo "Ensuring default development sites..."
py manage.py ensure_default_sites

# Check for existing Google OAuth app and create if not present
echo "Checking for existing Google OAuth configuration..."
GOOGLE_OAUTH_ARGS=()
if [ "${INTERACTIVE}" -eq 0 ]; then
    GOOGLE_OAUTH_ARGS+=(--non-interactive)
fi
py manage.py ensure_google_oauth "${GOOGLE_OAUTH_ARGS[@]}"

popd >/dev/null
