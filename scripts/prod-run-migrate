#!/usr/bin/env bash

set -euo pipefail

if [[ $# -lt 1 || $# -gt 3 ]]; then
    echo "Usage: $(basename "$0") <stack-name> [environment] [task-definition-arn]" >&2
    exit 2
fi

STACK_NAME="$1"
ENVIRONMENT="${2:-dev}"
TASK_DEFINITION_ARN="${3:-}"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/_aws_common.sh
source "${SCRIPT_DIR}/_aws_common.sh"

require_commands aws jq terraform
"${SCRIPT_DIR}/prod-ensure-terraform-state" >/dev/null
terraform_init "${STACK_NAME}" "${ENVIRONMENT}"

CLUSTER_NAME="$(terraform_output_raw cluster_name)"
WEB_SERVICE_NAME="$(terraform_output_raw web_service_name)"

if [[ -z "${TASK_DEFINITION_ARN}" ]]; then
    TASK_DEFINITION_ARN="$(current_service_task_definition "${CLUSTER_NAME}" "${WEB_SERVICE_NAME}")"
fi

OVERRIDES_JSON="$(
    jq -nc '{
        containerOverrides: [
            {
                name: "web",
                command: ["python3", "manage.py", "migrate"]
            }
        ]
    }'
)"

TASK_ARN="$(
    aws ecs run-task \
        --cluster "${CLUSTER_NAME}" \
        --launch-type EC2 \
        --task-definition "${TASK_DEFINITION_ARN}" \
        --overrides "${OVERRIDES_JSON}" \
        --query 'tasks[0].taskArn' \
        --output text
)"

[[ "${TASK_ARN}" != "None" ]] || fail "Failed to start migration task"

aws ecs wait tasks-stopped --cluster "${CLUSTER_NAME}" --tasks "${TASK_ARN}"

EXIT_CODE="$(
    aws ecs describe-tasks \
        --cluster "${CLUSTER_NAME}" \
        --tasks "${TASK_ARN}" \
        --query 'tasks[0].containers[?name==`web`].exitCode | [0]' \
        --output text
)"

if [[ "${EXIT_CODE}" != "0" ]]; then
    STOPPED_REASON="$(
        aws ecs describe-tasks \
            --cluster "${CLUSTER_NAME}" \
            --tasks "${TASK_ARN}" \
            --query 'tasks[0].stoppedReason' \
            --output text
    )"
    fail "Migration task failed with exit code ${EXIT_CODE}: ${STOPPED_REASON}"
fi

echo "Migration completed successfully on task ${TASK_ARN}"
