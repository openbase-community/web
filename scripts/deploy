#!/usr/bin/env bash

set -euo pipefail

if [[ $# -lt 1 || $# -gt 3 ]]; then
    echo "Usage: $(basename "$0") <stack-name> [environment] [image-tag]" >&2
    exit 2
fi

STACK_NAME="$1"
ENVIRONMENT="${2:-dev}"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/_aws_common.sh
source "${SCRIPT_DIR}/_aws_common.sh"

IMAGE_TAG="${3:-${IMAGE_TAG:-$(default_image_tag)}}"
WEB_IMAGE_URI="$(ecr_repository_uri "${STACK_NAME}" "${ENVIRONMENT}" "web"):${IMAGE_TAG}"
WORKER_IMAGE_URI="$(ecr_repository_uri "${STACK_NAME}" "${ENVIRONMENT}" "worker"):${IMAGE_TAG}"

require_commands aws jq terraform
"${SCRIPT_DIR}/ensure_terraform_state" >/dev/null
ensure_ecr_image_tag "${STACK_NAME}" "${ENVIRONMENT}" "web" "${IMAGE_TAG}"
ensure_ecr_image_tag "${STACK_NAME}" "${ENVIRONMENT}" "worker" "${IMAGE_TAG}"
terraform_init "${STACK_NAME}" "${ENVIRONMENT}"

CLUSTER_NAME="$(terraform_output_raw cluster_name)"
WEB_SERVICE_NAME="$(terraform_output_raw web_service_name)"
WORKER_SERVICE_NAME="$(terraform_output_raw worker_service_name)"

CURRENT_WEB_TASK_DEFINITION="$(current_service_task_definition "${CLUSTER_NAME}" "${WEB_SERVICE_NAME}")"
CURRENT_WORKER_TASK_DEFINITION="$(current_service_task_definition "${CLUSTER_NAME}" "${WORKER_SERVICE_NAME}")"

NEW_WEB_TASK_DEFINITION="$(
    register_task_definition_with_image \
        "${CURRENT_WEB_TASK_DEFINITION}" \
        "web" \
        "${WEB_IMAGE_URI}"
)"
NEW_WORKER_TASK_DEFINITION="$(
    register_task_definition_with_image \
        "${CURRENT_WORKER_TASK_DEFINITION}" \
        "worker" \
        "${WORKER_IMAGE_URI}"
)"

"${SCRIPT_DIR}/run_migrate" "${STACK_NAME}" "${ENVIRONMENT}" "${NEW_WEB_TASK_DEFINITION}"

aws ecs update-service \
    --cluster "${CLUSTER_NAME}" \
    --service "${WEB_SERVICE_NAME}" \
    --task-definition "${NEW_WEB_TASK_DEFINITION}" >/dev/null

aws ecs update-service \
    --cluster "${CLUSTER_NAME}" \
    --service "${WORKER_SERVICE_NAME}" \
    --task-definition "${NEW_WORKER_TASK_DEFINITION}" >/dev/null

aws ecs wait services-stable \
    --cluster "${CLUSTER_NAME}" \
    --services "${WEB_SERVICE_NAME}" "${WORKER_SERVICE_NAME}"

echo "Deployed ${STACK_NAME}/${ENVIRONMENT} with image tag ${IMAGE_TAG}"
echo "  web:    ${NEW_WEB_TASK_DEFINITION}"
echo "  worker: ${NEW_WORKER_TASK_DEFINITION}"
