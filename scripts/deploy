#!/usr/bin/env bash

set -euo pipefail

APP_NAME="$1"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd -- "${SCRIPT_DIR}/.." && pwd)"

cleanup() {
    "${SCRIPT_DIR}/cleanup_build_artifacts"
}

trap cleanup EXIT

cd "${REPO_DIR}"

"${SCRIPT_DIR}/cleanup_build_artifacts"

heroku container:release web worker beat release -a "$APP_NAME"
