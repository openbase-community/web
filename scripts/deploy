#!/usr/bin/env bash

set -euo pipefail

if [[ $# -lt 1 || $# -gt 3 ]]; then
    echo "Usage: $(basename "$0") <stack-name> [environment] [image-tag]" >&2
    exit 2
fi

STACK_NAME="$1"
ENVIRONMENT="${2:-dev}"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/internal/aws-common.sh
source "${SCRIPT_DIR}/internal/aws-common.sh"

IMAGE_TAG="${3:-${IMAGE_TAG:-$(require_deploy_config_value "${ENVIRONMENT}" "IMAGE_TAG")}}"
APP_IMAGE_URI="$(ecr_repository_uri "${STACK_NAME}" "${ENVIRONMENT}" "app"):${IMAGE_TAG}"

require_commands aws jq terraform
"${SCRIPT_DIR}/ensure-terraform-state" >/dev/null
ensure_ecr_image_tag "${STACK_NAME}" "${ENVIRONMENT}" "app" "${IMAGE_TAG}"
terraform_init "${STACK_NAME}" "${ENVIRONMENT}"

CLUSTER_NAME="$(terraform_output_raw cluster_name)"
WEB_SERVICE_NAME="$(terraform_output_raw web_service_name)"
WORKER_SERVICE_NAME="$(terraform_output_raw worker_service_name)"

CURRENT_WEB_TASK_DEFINITION="$(terraform_managed_task_definition web)"
CURRENT_WORKER_TASK_DEFINITION="$(terraform_managed_task_definition worker)"

NEW_WEB_TASK_DEFINITION="$(
    register_task_definition_with_image \
        "${CURRENT_WEB_TASK_DEFINITION}" \
        "web" \
        "${APP_IMAGE_URI}"
)"
NEW_WORKER_TASK_DEFINITION="$(
    register_task_definition_with_image \
        "${CURRENT_WORKER_TASK_DEFINITION}" \
        "worker" \
        "${APP_IMAGE_URI}"
)"

"${SCRIPT_DIR}/internal/run-migrate" "${STACK_NAME}" "${ENVIRONMENT}" "${NEW_WEB_TASK_DEFINITION}"

aws ecs update-service \
    --cluster "${CLUSTER_NAME}" \
    --service "${WEB_SERVICE_NAME}" \
    --task-definition "${NEW_WEB_TASK_DEFINITION}" >/dev/null

aws ecs update-service \
    --cluster "${CLUSTER_NAME}" \
    --service "${WORKER_SERVICE_NAME}" \
    --task-definition "${NEW_WORKER_TASK_DEFINITION}" >/dev/null

aws ecs wait services-stable \
    --cluster "${CLUSTER_NAME}" \
    --services "${WEB_SERVICE_NAME}" "${WORKER_SERVICE_NAME}"

echo "Deployed ${STACK_NAME}/${ENVIRONMENT} with image tag ${IMAGE_TAG}"
echo "  image:  ${APP_IMAGE_URI}"
echo "  web:    ${NEW_WEB_TASK_DEFINITION}"
echo "  worker: ${NEW_WORKER_TASK_DEFINITION}"
