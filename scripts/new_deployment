#!/usr/bin/env bash

set -euo pipefail

if [[ $# -lt 1 || $# -gt 2 ]]; then
    echo "Usage: $(basename "$0") <stack-name> [environment]" >&2
    exit 2
fi

STACK_NAME="$1"
ENVIRONMENT="${2:-dev}"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "${SCRIPT_DIR}/_aws_common.sh"

require_commands aws

TFVARS_FILE="$(tfvars_file_for_environment "${ENVIRONMENT}")"
WEB_IMAGE_URI="$(ecr_repository_uri "${STACK_NAME}" "${ENVIRONMENT}" "web")"
WORKER_IMAGE_URI="$(ecr_repository_uri "${STACK_NAME}" "${ENVIRONMENT}" "worker")"
DJANGO_SECRET_ARN="arn:aws:ssm:${AWS_REGION}:$(aws_account_id):parameter/${STACK_NAME}/${ENVIRONMENT}/django-secret-key"

if [[ -e "${TFVARS_FILE}" ]]; then
    fail "Terraform vars file already exists: ${TFVARS_FILE}"
fi

cat > "${TFVARS_FILE}" <<EOF
name        = "${STACK_NAME}"
environment = "${ENVIRONMENT}"
aws_region  = "${AWS_REGION}"
web_hostname = "api.example.com"

web_image    = "${WEB_IMAGE_URI}:bootstrap"
worker_image = "${WORKER_IMAGE_URI}:bootstrap"

db_password = "replace-me"

web_ingress_cidrs = ["0.0.0.0/0"]
cloudflare_origin_cert_parameter_name = "/${STACK_NAME}/${ENVIRONMENT}/cloudflare-origin-cert"
cloudflare_origin_key_parameter_name  = "/${STACK_NAME}/${ENVIRONMENT}/cloudflare-origin-key"

common_environment = {
  DJANGO_DEBUG = "0"
}

common_secrets = {
  DJANGO_SECRET_KEY = "${DJANGO_SECRET_ARN}"
}
EOF

echo "Created ${TFVARS_FILE}"
echo
echo "Next steps:"
echo "  1. Set TF_STATE_BUCKET in your shell."
echo "  2. Create the SSM parameter for DJANGO_SECRET_KEY:"
echo "     aws ssm put-parameter --name \"/${STACK_NAME}/${ENVIRONMENT}/django-secret-key\" --type SecureString --value \"\$(openssl rand -base64 32)\""
echo "  3. Fill in web_hostname, db_password, and any additional settings in ${TFVARS_FILE}."
echo "  4. Build images: ./scripts/build ${STACK_NAME} \"https://github.com/openbase-community/openbase-cloud-api\" ${ENVIRONMENT}"
echo "  5. Apply infra: ./scripts/infra_apply ${STACK_NAME} ${ENVIRONMENT}"
echo "  6. Export CLOUDFLARE_API_TOKEN with permissions for Zone DNS Write, Zone Settings Write, Zone Read, and SSL/TLS Write."
echo "  7. Configure Cloudflare DNS + Origin CA automatically: ./scripts/cloudflare_setup ${STACK_NAME} ${ENVIRONMENT}"
echo "  8. Deploy web + worker together: ./scripts/deploy ${STACK_NAME} ${ENVIRONMENT}"
