#!/usr/bin/env bash

set -euo pipefail

if [[ $# -lt 1 || $# -gt 3 ]]; then
    echo "Usage: $(basename "$0") <stack-name> [environment] [image-tag]" >&2
    exit 2
fi

STACK_NAME="$1"
ENVIRONMENT="${2:-dev}"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/internal/aws-common.sh
source "${SCRIPT_DIR}/internal/aws-common.sh"

IMAGE_TAG="${3:-${IMAGE_TAG:-$(require_deploy_config_value "${ENVIRONMENT}" "IMAGE_TAG")}}"
TFVARS_FILE="$(require_tfvars_file "${ENVIRONMENT}")"
APP_IMAGE_URI="$(ecr_repository_uri "${STACK_NAME}" "${ENVIRONMENT}" "app"):${IMAGE_TAG}"

require_commands aws terraform
"${SCRIPT_DIR}/ensure-terraform-state"
ensure_ecr_repository "${STACK_NAME}" "${ENVIRONMENT}" "app"
ensure_ecr_image_tag "${STACK_NAME}" "${ENVIRONMENT}" "app" "${IMAGE_TAG}"
terraform_init "${STACK_NAME}" "${ENVIRONMENT}"

terraform -chdir="${TERRAFORM_DIR}" apply \
    -var-file="${TFVARS_FILE}" \
    -var "name=${STACK_NAME}" \
    -var "environment=${ENVIRONMENT}" \
    -var "app_image=${APP_IMAGE_URI}"
