#!/usr/bin/env bash

set -euo pipefail

if [[ $# -lt 1 || $# -gt 4 ]]; then
    echo "Usage: $(basename "$0") <stack-name> [app-requirements] [environment] [image-tag]" >&2
    exit 2
fi

STACK_NAME="$1"
APP_REQUIREMENTS="${2:-${APP_REQUIREMENTS:-}}"
ENVIRONMENT="${3:-dev}"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/_aws_common.sh
source "${SCRIPT_DIR}/_aws_common.sh"

IMAGE_TAG="${4:-${IMAGE_TAG:-$(default_image_tag)}}"
APP_IMAGE_REPOSITORY="$(ecr_repository_uri "${STACK_NAME}" "${ENVIRONMENT}" "app")"

require_commands aws docker git sed uv
ensure_ecr_repository "${STACK_NAME}" "${ENVIRONMENT}" "app"
ecr_login

PRIVATE_GITHUB_REPOS_TMP="./.private_github_repos.build.$$"
NOCACHE_TMP="./.nocache.build.$$"

cleanup() {
    "${SCRIPT_DIR}/cleanup_build_artifacts"
}

trap cleanup EXIT

cd "${REPO_DIR}"

"${SCRIPT_DIR}/cleanup_build_artifacts"

if [[ -z "${APP_REQUIREMENTS}" ]]; then
    printf '%s\n' "git+https://github.com/openbase-community/openbase-cloud-api" > "${PRIVATE_GITHUB_REPOS_TMP}"
else
    printf '%s' "${APP_REQUIREMENTS}" | tr ',' '\n' | while IFS= read -r requirement; do
        requirement="${requirement#"${requirement%%[![:space:]]*}"}"
        requirement="${requirement%"${requirement##*[![:space:]]}"}"
        if [[ -z "${requirement}" ]]; then
            continue
        fi
        if [[ "${requirement}" == https://github.com/* ]]; then
            printf 'git+%s\n' "${requirement}"
        else
            printf '%s\n' "${requirement}"
        fi
    done > "${PRIVATE_GITHUB_REPOS_TMP}"
fi

date > "${NOCACHE_TMP}"

DOCKERFILE_TMP="./.dockerfile.build.app.$$"

sed \
    -e "s|COPY nocache.txt /tmp/nocache.txt|COPY ${NOCACHE_TMP#./} /tmp/nocache.txt|" \
    -e "s|COPY private_github_repos.txt /tmp/private_github_repos.txt|COPY ${PRIVATE_GITHUB_REPOS_TMP#./} /tmp/private_github_repos.txt|" \
    ./Dockerfile > "${DOCKERFILE_TMP}"

docker buildx build \
    --platform linux/amd64 \
    --push \
    -t "${APP_IMAGE_REPOSITORY}:${IMAGE_TAG}" \
    -t "${APP_IMAGE_REPOSITORY}:latest" \
    -f "${DOCKERFILE_TMP}" \
    --secret id=gh_pat,env=GH_PAT \
    --provenance false \
    .

rm -f "${DOCKERFILE_TMP}"

echo "Built and pushed:"
echo "  ${APP_IMAGE_REPOSITORY}:${IMAGE_TAG}"
