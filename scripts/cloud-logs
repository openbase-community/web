#!/usr/bin/env bash

set -euo pipefail
trap 'exit 0' PIPE

usage() {
    cat <<'EOF'
Usage: cloud-logs <stack-name> [environment] [--tail] [--lines <count>]

Examples:
  ./scripts/cloud-logs openbase-api-core prod
  ./scripts/cloud-logs openbase-api-core prod --lines 200
  ./scripts/cloud-logs openbase-api-core prod --tail

Environment overrides:
  LOGS_LOOKBACK_SECONDS      Initial lookback window in seconds. Default: 900
  LOGS_MAX_LOOKBACK_SECONDS  Max lookback window used with --lines. Default: 604800
  LOGS_POLL_SECONDS          Poll interval when using --tail. Default: 2
EOF
}

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/internal/aws-common.sh
source "${SCRIPT_DIR}/internal/aws-common.sh"

require_commands aws jq python3

STACK_NAME=""
ENVIRONMENT="dev"
ENVIRONMENT_SET=false
TAIL=false
LINE_COUNT=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --tail)
            TAIL=true
            shift
            ;;
        --lines)
            shift
            [[ $# -gt 0 ]] || fail "Missing value for --lines"
            [[ "$1" =~ ^[1-9][0-9]*$ ]] || fail "--lines must be a positive integer"
            LINE_COUNT="$1"
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        -*)
            fail "Unknown option: $1"
            ;;
        *)
            if [[ -z "${STACK_NAME}" ]]; then
                STACK_NAME="$1"
            elif [[ "${ENVIRONMENT_SET}" == "false" ]]; then
                ENVIRONMENT="$1"
                ENVIRONMENT_SET=true
            else
                fail "Unexpected argument: $1"
            fi
            shift
            ;;
    esac
done

[[ -n "${STACK_NAME}" ]] || {
    usage >&2
    exit 2
}

LOOKBACK_SECONDS="${LOGS_LOOKBACK_SECONDS:-900}"
MAX_LOOKBACK_SECONDS="${LOGS_MAX_LOOKBACK_SECONDS:-604800}"
POLL_SECONDS="${LOGS_POLL_SECONDS:-2}"

WEB_LOG_GROUP="/ecs/${STACK_NAME}-${ENVIRONMENT}/web"
WORKER_LOG_GROUP="/ecs/${STACK_NAME}-${ENVIRONMENT}/worker"
CADDY_LOG_GROUP="/ecs/${STACK_NAME}-${ENVIRONMENT}/caddy"
SEEN_EVENT_IDS_FILE="$(mktemp "${TMPDIR:-/tmp}/api-core-logs-seen.XXXXXX")"

trap 'rm -f "${SEEN_EVENT_IDS_FILE}"' EXIT

now_ms() {
    python3 - <<'PY'
import time
print(int(time.time() * 1000))
PY
}

format_timestamp() {
    local timestamp_ms="$1"
    date -r "$((timestamp_ms / 1000))" '+%Y-%m-%d %H:%M:%S'
}

fetch_events() {
    local log_group="$1"
    local component="$2"
    local start_ms="$3"

    if ! aws logs filter-log-events \
        --log-group-name "${log_group}" \
        --start-time "${start_ms}" \
        --output json 2>/dev/null | jq \
        --arg component "${component}" \
        '[.events[]? | {
            timestamp,
            event_id: .eventId,
            component: $component,
            message: (.message | sub("\n$"; "")),
            stream: .logStreamName
        }]'; then
        printf '[]\n'
    fi
}

print_merged_events() {
    local merged_json="$1"
    local latest="${LATEST_SEEN_MS}"

    while IFS=$'\t' read -r event_id timestamp_ms component message; do
        local formatted_timestamp

        [[ -n "${event_id}" && "${event_id}" != "null" ]] || continue

        if grep -Fqx "${event_id}" "${SEEN_EVENT_IDS_FILE}"; then
            continue
        fi
        printf '%s\n' "${event_id}" >> "${SEEN_EVENT_IDS_FILE}"
        formatted_timestamp="$(format_timestamp "${timestamp_ms}")"

        if ! printf '%s %s: %s\n' "${formatted_timestamp}" "${component}" "${message}" 2>/dev/null; then
            exit 0
        fi

        if (( timestamp_ms > latest )); then
            latest="${timestamp_ms}"
        fi
    done < <(jq -r '.[] | [.event_id, (.timestamp | tostring), .component, (.message | gsub("\n"; "\\n"))] | @tsv' <<<"${merged_json}")

    LATEST_SEEN_MS="${latest}"
}

read_logs_since() {
    local start_ms="$1"
    jq -s 'add | sort_by(.timestamp, .component, .event_id)' \
        <(fetch_events "${CADDY_LOG_GROUP}" "caddy" "${start_ms}") \
        <(fetch_events "${WEB_LOG_GROUP}" "web" "${start_ms}") \
        <(fetch_events "${WORKER_LOG_GROUP}" "worker" "${start_ms}")
}

merged_event_count() {
    local merged_json="$1"
    jq 'length' <<<"${merged_json}"
}

tail_merged_events() {
    local merged_json="$1"
    local line_count="$2"
    jq --argjson line_count "${line_count}" 'if length > $line_count then .[-$line_count:] else . end' <<<"${merged_json}"
}

read_initial_logs() {
    local now
    local start_ms
    local merged
    local current_lookback
    local event_count

    now="$(now_ms)"

    if [[ -z "${LINE_COUNT}" ]]; then
        start_ms="$((now - (LOOKBACK_SECONDS * 1000) ))"
        LATEST_SEEN_MS="${start_ms}"
        read_logs_since "${start_ms}"
        return
    fi

    current_lookback="${LOOKBACK_SECONDS}"
    if (( current_lookback <= 0 )); then
        current_lookback=1
    fi

    while true; do
        start_ms="$((now - (current_lookback * 1000) ))"
        merged="$(read_logs_since "${start_ms}")"
        event_count="$(merged_event_count "${merged}")"

        if (( event_count >= LINE_COUNT || current_lookback >= MAX_LOOKBACK_SECONDS )); then
            LATEST_SEEN_MS="${start_ms}"
            tail_merged_events "${merged}" "${LINE_COUNT}"
            return
        fi

        current_lookback="$(( current_lookback * 2 ))"
        if (( current_lookback > MAX_LOOKBACK_SECONDS )); then
            current_lookback="${MAX_LOOKBACK_SECONDS}"
        fi
    done
}

INITIAL_MERGED="$(read_initial_logs)"

if [[ "$(merged_event_count "${INITIAL_MERGED}")" == "0" ]]; then
    if [[ "${TAIL}" == "true" ]]; then
        if [[ -n "${LINE_COUNT}" ]]; then
            echo "No caddy/web/worker logs found while looking for the last ${LINE_COUNT} lines. Waiting for new logs..." >&2
        else
            echo "No caddy/web/worker logs found in the last ${LOOKBACK_SECONDS} seconds. Waiting for new logs..." >&2
        fi
    else
        if [[ -n "${LINE_COUNT}" ]]; then
            echo "No caddy/web/worker logs found while looking for the last ${LINE_COUNT} lines." >&2
        else
            echo "No caddy/web/worker logs found in the last ${LOOKBACK_SECONDS} seconds." >&2
        fi
    fi
fi

print_merged_events "${INITIAL_MERGED}"

if [[ "${TAIL}" != "true" ]]; then
    exit 0
fi

while true; do
    sleep "${POLL_SECONDS}"
    POLL_START_MS="$((LATEST_SEEN_MS > 1000 ? LATEST_SEEN_MS - 1000 : 0))"
    MERGED="$(read_logs_since "${POLL_START_MS}")"
    print_merged_events "${MERGED}"
done
