#!/usr/bin/env bash

set -euo pipefail

if [[ $# -lt 1 || $# -gt 2 ]]; then
    echo "Usage: $(basename "$0") <stack-name> [environment]" >&2
    exit 2
fi

STACK_NAME="$1"
ENVIRONMENT="${2:-dev}"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "${SCRIPT_DIR}/internal/aws-common.sh"

require_commands aws

TFVARS_FILE="$(tfvars_file_for_environment "${ENVIRONMENT}")"
DEPLOY_CONFIG_FILE="$(deploy_config_file_for_environment "${ENVIRONMENT}")"
APP_IMAGE_URI="$(ecr_repository_uri "${STACK_NAME}" "${ENVIRONMENT}" "app")"
DJANGO_SECRET_ARN="arn:aws:ssm:${AWS_REGION}:$(aws_account_id):parameter/${STACK_NAME}/${ENVIRONMENT}/django-secret-key"

if [[ -e "${TFVARS_FILE}" ]]; then
    fail "Terraform vars file already exists: ${TFVARS_FILE}"
fi

if [[ -e "${DEPLOY_CONFIG_FILE}" ]]; then
    fail "Deploy config file already exists: ${DEPLOY_CONFIG_FILE}"
fi

cat > "${TFVARS_FILE}" <<EOF
name        = "${STACK_NAME}"
environment = "${ENVIRONMENT}"
aws_region  = "${AWS_REGION}"
web_hostname = "api.example.com"
cloudflare_zone_name = "example.com"

app_image = "${APP_IMAGE_URI}:bootstrap"

db_password = "replace-me"

cloudflare_origin_cert_parameter_name = "/${STACK_NAME}/${ENVIRONMENT}/cloudflare-origin-cert"
cloudflare_origin_key_parameter_name  = "/${STACK_NAME}/${ENVIRONMENT}/cloudflare-origin-key"

common_secrets = {
  DJANGO_SECRET_KEY = "${DJANGO_SECRET_ARN}"
}
EOF

ensure_deploy_dir
cat > "${DEPLOY_CONFIG_FILE}" <<'EOF'
# Untracked per-environment deploy inputs for build and rollout.

APP_REQUIREMENTS=''
IMAGE_TAG=''
EOF

echo "Created ${TFVARS_FILE}"
echo "Created ${DEPLOY_CONFIG_FILE}"
echo
echo "Next steps:"
echo "  1. Set TF_STATE_BUCKET in your shell."
echo "  2. Create DJANGO_SECRET_KEY in SSM + tfvars:"
echo "     openssl rand -base64 32 | ./scripts/cloud-config set ${STACK_NAME} ${ENVIRONMENT} DJANGO_SECRET_KEY"
echo "  3. Fill in web_hostname and db_password in ${TFVARS_FILE}."
echo "  4. Set APP_REQUIREMENTS in ${DEPLOY_CONFIG_FILE}."
echo "     For any operator-managed app config, use ./scripts/cloud-config set ${STACK_NAME} ${ENVIRONMENT} <ENV_VAR>"
echo "  5. Build the app image: ./scripts/build ${STACK_NAME} ${ENVIRONMENT}"
echo "  6. Export CLOUDFLARE_API_TOKEN with permissions for Zone:Read, DNS:Edit, Config Rules:Edit, and SSL and Certificates:Edit."
echo "  7. Apply infra: ./scripts/infra-apply ${STACK_NAME} ${ENVIRONMENT}"
echo "  8. Issue the Cloudflare Origin CA cert + reload Caddy: ./scripts/cloudflare-setup ${STACK_NAME} ${ENVIRONMENT}"
echo "  9. Deploy web + worker together: ./scripts/deploy ${STACK_NAME} ${ENVIRONMENT}"
