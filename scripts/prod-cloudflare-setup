#!/usr/bin/env bash

set -euo pipefail

if [[ $# -lt 1 || $# -gt 2 ]]; then
    echo "Usage: $(basename "$0") <stack-name> [environment]" >&2
    exit 2
fi

STACK_NAME="$1"
ENVIRONMENT="${2:-dev}"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/_aws_common.sh
source "${SCRIPT_DIR}/_aws_common.sh"

require_commands aws curl jq openssl terraform
require_env CLOUDFLARE_API_TOKEN

terraform_output_raw_if_present() {
    local output_name="$1"

    terraform -chdir="${TERRAFORM_DIR}" output -raw "${output_name}" 2>/dev/null || true
}

cloudflare_api() {
    local method="$1"
    local path="$2"
    local data="${3:-}"
    local response

    if [[ -n "${data}" ]]; then
        response="$(
            curl -fsS \
                -X "${method}" \
                -H "Authorization: Bearer ${CLOUDFLARE_API_TOKEN}" \
                -H "Content-Type: application/json" \
                "https://api.cloudflare.com/client/v4${path}" \
                --data "${data}"
        )"
    else
        response="$(
            curl -fsS \
                -X "${method}" \
                -H "Authorization: Bearer ${CLOUDFLARE_API_TOKEN}" \
                -H "Content-Type: application/json" \
                "https://api.cloudflare.com/client/v4${path}"
        )"
    fi

    if [[ "$(jq -r '.success // false' <<<"${response}")" != "true" ]]; then
        fail "Cloudflare API ${method} ${path} failed: $(jq -r '[.errors[]? | .message] | join(\"; \") // \"unknown error\"' <<<"${response}")"
    fi

    printf '%s\n' "${response}"
}

cloudflare_zone_id_for_name() {
    local zone_name="$1"
    local response
    local zone_id

    response="$(cloudflare_api GET "/zones?name=${zone_name}")"
    zone_id="$(jq -r --arg zone_name "${zone_name}" '.result[] | select(.name == $zone_name) | .id' <<<"${response}" | head -n1)"

    [[ -n "${zone_id}" ]] || fail "Could not find Cloudflare zone named ${zone_name}"
    printf '%s\n' "${zone_id}"
}

cloudflare_zone_id_for_hostname() {
    local hostname="$1"
    local zone_parts
    local zone_candidate
    local i

    if [[ -n "${CLOUDFLARE_ZONE_ID:-}" ]]; then
        printf '%s\n' "${CLOUDFLARE_ZONE_ID}"
        return
    fi

    if [[ -n "${CLOUDFLARE_ZONE_NAME:-}" ]]; then
        cloudflare_zone_id_for_name "${CLOUDFLARE_ZONE_NAME}"
        return
    fi

    IFS='.' read -r -a zone_parts <<<"${hostname}"
    for ((i = 0; i <= ${#zone_parts[@]} - 2; i++)); do
        local suffix_parts=("${zone_parts[@]:i}")
        zone_candidate="$(IFS=.; echo "${suffix_parts[*]}")"
        if cloudflare_zone_id_for_name "${zone_candidate}" >/dev/null 2>&1; then
            cloudflare_zone_id_for_name "${zone_candidate}"
            return
        fi
    done

    fail "Could not infer a Cloudflare zone for ${hostname}. Set CLOUDFLARE_ZONE_NAME or CLOUDFLARE_ZONE_ID."
}

cloudflare_upsert_a_record() {
    local zone_id="$1"
    local hostname="$2"
    local origin_ip="$3"
    cloudflare_upsert_dns_record "${zone_id}" "A" "${hostname}" "${origin_ip}"
}

cloudflare_upsert_cname_record() {
    local zone_id="$1"
    local hostname="$2"
    local target="$3"
    cloudflare_upsert_dns_record "${zone_id}" "CNAME" "${hostname}" "${target}"
}

cloudflare_upsert_dns_record() {
    local zone_id="$1"
    local record_type="$2"
    local hostname="$3"
    local content="$4"
    local response
    local matching_record_count
    local conflicting_count
    local record_id
    local payload

    response="$(cloudflare_api GET "/zones/${zone_id}/dns_records?name=${hostname}&per_page=100")"
    matching_record_count="$(jq -r --arg hostname "${hostname}" --arg record_type "${record_type}" '[.result[] | select(.name == $hostname and .type == $record_type)] | length' <<<"${response}")"
    conflicting_count="$(jq -r --arg hostname "${hostname}" --arg record_type "${record_type}" '[.result[] | select(.name == $hostname and .type != $record_type)] | length' <<<"${response}")"

    if (( conflicting_count > 0 )); then
        fail "Cloudflare already has a different record type for ${hostname}. Resolve that conflict before running this script."
    fi

    if (( matching_record_count > 1 )); then
        fail "Cloudflare has multiple ${record_type} records for ${hostname}. This script expects exactly one or zero."
    fi

    payload="$(jq -nc --arg hostname "${hostname}" --arg record_type "${record_type}" --arg content "${content}" '{
        type: $record_type,
        name: $hostname,
        content: $content,
        proxied: true,
        ttl: 1
    }')"

    if (( matching_record_count == 1 )); then
        record_id="$(jq -r --arg hostname "${hostname}" --arg record_type "${record_type}" '.result[] | select(.name == $hostname and .type == $record_type) | .id' <<<"${response}")"
        cloudflare_api PUT "/zones/${zone_id}/dns_records/${record_id}" "${payload}" >/dev/null
    else
        cloudflare_api POST "/zones/${zone_id}/dns_records" "${payload}" >/dev/null
    fi
}

cloudflare_upsert_ssl_flexible_config_rule() {
    local zone_id="$1"
    local hostname="$2"
    local rule_ref="openbase_cdn_ssl_flexible"
    local description="Use flexible SSL for the CDN hostname backed by the S3 website endpoint"
    local expression
    local response
    local status_code
    local rules_payload
    local existing_rules

    expression="(http.host eq \"${hostname}\")"
    response="$(
        curl -sS \
            -w '\n%{http_code}' \
            -X GET \
            -H "Authorization: Bearer ${CLOUDFLARE_API_TOKEN}" \
            -H "Content-Type: application/json" \
            "https://api.cloudflare.com/client/v4/zones/${zone_id}/rulesets/phases/http_config_settings/entrypoint"
    )"
    status_code="$(tail -n1 <<<"${response}")"
    response="$(sed '$d' <<<"${response}")"

    case "${status_code}" in
        200)
            existing_rules="$(jq --arg rule_ref "${rule_ref}" --arg expression "${expression}" --arg description "${description}" '
                .result.rules // []
                | map(
                    if .ref == $rule_ref then
                        .expression = $expression
                        | .description = $description
                        | .action = "set_config"
                        | .enabled = true
                        | .action_parameters.ssl = "flexible"
                    else
                        .
                    end
                )
                | if any(.ref == $rule_ref) then
                    .
                  else
                    . + [{
                        ref: $rule_ref,
                        description: $description,
                        expression: $expression,
                        action: "set_config",
                        action_parameters: { ssl: "flexible" },
                        enabled: true
                    }]
                  end
            ' <<<"${response}")"

            rules_payload="$(jq -nc --argjson rules "${existing_rules}" '{rules: $rules}')"
            if ! cloudflare_api PUT "/zones/${zone_id}/rulesets/phases/http_config_settings/entrypoint" "${rules_payload}" >/dev/null; then
                echo "Warning: Could not update the Cloudflare configuration rule for ${hostname}. Your token likely needs Configuration Rules / Rulesets edit permissions." >&2
                return 1
            fi
            ;;
        404)
            rules_payload="$(jq -nc --arg rule_ref "${rule_ref}" --arg expression "${expression}" --arg description "${description}" '{
                name: "Zone-level configuration rules",
                kind: "zone",
                phase: "http_config_settings",
                rules: [
                    {
                        ref: $rule_ref,
                        description: $description,
                        expression: $expression,
                        action: "set_config",
                        action_parameters: {
                            ssl: "flexible"
                        },
                        enabled: true
                    }
                ]
            }')"
            if ! cloudflare_api POST "/zones/${zone_id}/rulesets" "${rules_payload}" >/dev/null; then
                echo "Warning: Could not create the Cloudflare configuration rule for ${hostname}. Your token likely needs Configuration Rules / Rulesets edit permissions." >&2
                return 1
            fi
            ;;
        *)
            echo "Warning: Could not inspect Cloudflare configuration rules for ${hostname}: $(jq -r '[.errors[]? | .message] | join(\"; \") // \"unknown error\"' <<<"${response}")" >&2
            return 1
            ;;
    esac
}

issue_origin_certificate() {
    local hostname="$1"
    local cert_parameter_name="$2"
    local key_parameter_name="$3"
    local tmp_dir
    local key_file
    local csr_file
    local openssl_config_file
    local payload
    local response
    local certificate

    tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/openbase-cloudflare-origin.XXXXXX")"
    key_file="${tmp_dir}/origin.key"
    csr_file="${tmp_dir}/origin.csr"
    openssl_config_file="${tmp_dir}/openssl.cnf"

    cat > "${openssl_config_file}" <<EOF
[req]
distinguished_name = req_distinguished_name
req_extensions = v3_req
prompt = no

[req_distinguished_name]
CN = ${hostname}

[v3_req]
subjectAltName = @alt_names

[alt_names]
DNS.1 = ${hostname}
EOF

    openssl req \
        -new \
        -newkey rsa:2048 \
        -nodes \
        -keyout "${key_file}" \
        -out "${csr_file}" \
        -config "${openssl_config_file}" >/dev/null 2>&1

    payload="$(jq -n --arg hostname "${hostname}" --rawfile csr "${csr_file}" '{
        hostnames: [$hostname],
        request_type: "origin-rsa",
        requested_validity: 5475,
        csr: $csr
    }')"

    response="$(cloudflare_api POST "/certificates" "${payload}")"
    certificate="$(jq -r '.result.certificate' <<<"${response}")"

    [[ -n "${certificate}" && "${certificate}" != "null" ]] || fail "Cloudflare did not return an Origin CA certificate"

    aws ssm put-parameter \
        --name "${cert_parameter_name}" \
        --type SecureString \
        --overwrite \
        --value "${certificate}" >/dev/null

    aws ssm put-parameter \
        --name "${key_parameter_name}" \
        --type SecureString \
        --overwrite \
        --value "$(cat "${key_file}")" >/dev/null

    rm -rf "${tmp_dir}"
}

reload_caddy_from_ssm() {
    local instance_id="$1"
    local cert_parameter_name="$2"
    local key_parameter_name="$3"
    local command_id
    local status
    local commands
    local parameters_json

    commands="$(jq -nc \
        --arg region "${AWS_REGION}" \
        --arg cert_parameter_name "${cert_parameter_name}" \
        --arg key_parameter_name "${key_parameter_name}" \
        '[
            "set -euo pipefail",
            "aws ssm get-parameter --region " + $region + " --with-decryption --name \"" + $cert_parameter_name + "\" --query Parameter.Value --output text > /etc/caddy/cloudflare-origin.crt",
            "aws ssm get-parameter --region " + $region + " --with-decryption --name \"" + $key_parameter_name + "\" --query Parameter.Value --output text > /etc/caddy/cloudflare-origin.key",
            "chown root:caddy /etc/caddy/cloudflare-origin.crt /etc/caddy/cloudflare-origin.key",
            "chmod 0640 /etc/caddy/cloudflare-origin.crt /etc/caddy/cloudflare-origin.key",
            "systemctl reload-or-restart caddy"
        ]')"
    parameters_json="$(jq -nc --argjson commands "${commands}" '{commands: $commands}')"

    command_id="$(
        aws ssm send-command \
            --instance-ids "${instance_id}" \
            --document-name "AWS-RunShellScript" \
            --parameters "${parameters_json}" \
            --query 'Command.CommandId' \
            --output text
    )"

    while true; do
        status="$(
            aws ssm get-command-invocation \
                --command-id "${command_id}" \
                --instance-id "${instance_id}" \
                --query 'Status' \
                --output text 2>/dev/null || true
        )"

        case "${status}" in
            Success)
                return
                ;;
            Pending|InProgress|Delayed|"")
                sleep 2
                ;;
            *)
                fail "Failed to reload Caddy via SSM: ${status}"
                ;;
        esac
    done
}

web_instance_id_from_aws() {
    local instance_id

    instance_id="$(
        aws ec2 describe-instances \
            --filters \
                "Name=tag:Project,Values=${STACK_NAME}" \
                "Name=tag:Environment,Values=${ENVIRONMENT}" \
                "Name=tag:Role,Values=web" \
                "Name=instance-state-name,Values=pending,running,stopping,stopped" \
            --query 'Reservations[].Instances[].InstanceId' \
            --output text | awk 'NF { print $1; exit }'
    )"

    [[ -n "${instance_id}" ]] || fail "Could not find the web EC2 instance from AWS tags"
    printf '%s\n' "${instance_id}"
}

"${SCRIPT_DIR}/prod-ensure-terraform-state" >/dev/null
terraform_init "${STACK_NAME}" "${ENVIRONMENT}"

WEB_HOSTNAME="$(terraform_output_raw web_hostname)"
WEB_ORIGIN_IP="$(terraform_output_raw web_origin_ip)"
CDN_HOSTNAME="$(terraform_output_raw_if_present cdn_hostname)"
BUCKET_WEBSITE_ENDPOINT="$(terraform_output_raw_if_present bucket_website_endpoint)"
WEB_INSTANCE_ID="$(terraform_output_raw_if_present web_instance_id)"
CERT_PARAMETER_NAME="$(terraform_output_raw_if_present cloudflare_origin_cert_parameter_name)"
KEY_PARAMETER_NAME="$(terraform_output_raw_if_present cloudflare_origin_key_parameter_name)"

if [[ -z "${WEB_INSTANCE_ID}" ]]; then
    WEB_INSTANCE_ID="$(web_instance_id_from_aws)"
fi

if [[ -z "${CERT_PARAMETER_NAME}" ]]; then
    CERT_PARAMETER_NAME="/${STACK_NAME}/${ENVIRONMENT}/cloudflare-origin-cert"
fi

if [[ -z "${KEY_PARAMETER_NAME}" ]]; then
    KEY_PARAMETER_NAME="/${STACK_NAME}/${ENVIRONMENT}/cloudflare-origin-key"
fi

ZONE_ID="$(cloudflare_zone_id_for_hostname "${WEB_HOSTNAME}")"

issue_origin_certificate "${WEB_HOSTNAME}" "${CERT_PARAMETER_NAME}" "${KEY_PARAMETER_NAME}"
reload_caddy_from_ssm "${WEB_INSTANCE_ID}" "${CERT_PARAMETER_NAME}" "${KEY_PARAMETER_NAME}"
cloudflare_upsert_a_record "${ZONE_ID}" "${WEB_HOSTNAME}" "${WEB_ORIGIN_IP}"

if [[ -n "${CDN_HOSTNAME}" && -n "${BUCKET_WEBSITE_ENDPOINT}" ]]; then
    cloudflare_upsert_cname_record "${ZONE_ID}" "${CDN_HOSTNAME}" "${BUCKET_WEBSITE_ENDPOINT}"
    cloudflare_upsert_ssl_flexible_config_rule "${ZONE_ID}" "${CDN_HOSTNAME}" || true
fi

echo "Configured Cloudflare for ${WEB_HOSTNAME}"
echo "  zone:      ${ZONE_ID}"
echo "  origin IP: ${WEB_ORIGIN_IP}"
if [[ -n "${CDN_HOSTNAME}" && -n "${BUCKET_WEBSITE_ENDPOINT}" ]]; then
echo "  cdn host:  ${CDN_HOSTNAME} -> ${BUCKET_WEBSITE_ENDPOINT}"
echo "  cdn ssl:   Flexible via Cloudflare configuration rule for ${CDN_HOSTNAME}"
fi
echo
echo "Manual Cloudflare step still required:"
echo "  Set SSL/TLS mode to Full (strict) for ${WEB_HOSTNAME} in the Cloudflare dashboard."
